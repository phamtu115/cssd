function doGet() {
  return HtmlService.createHtmlOutputFromFile("trangthaidungcu")
    .setTitle("THEO DÕI TIẾN ĐỘ DỤNG CỤ PHẪU THUẬT");
}

function getData() {
  const ss = SpreadsheetApp.openById('19vz99n7clMN3ey4k_SSD8iXYIhZe0IR0oh5oaZZs2ro');
  const sheet = ss.getSheetByName("TIETKHUANDUNGCU");
  const data = sheet.getDataRange().getDisplayValues();

  return data.slice(1).map(r => ({
    id: r[0], // ✅ cột A
    trangthai: r[11],
    tenbo: r[3],
    donle: r[4],
    thuthuat: r[5],
    ngay: r[1],
    giodukienhoanthanh: r[12],
  }));
}

function getLastUpdate() {
  const sheet = SpreadsheetApp.openById('19vz99n7clMN3ey4k_SSD8iXYIhZe0IR0oh5oaZZs2ro')
    .getSheetByName('TIETKHUANDUNGCU');
  return sheet.getRange("M2").getValue().toString();
}

function updateStatus(id, trangthai) {
  const sheet = SpreadsheetApp.openById('19vz99n7clMN3ey4k_SSD8iXYIhZe0IR0oh5oaZZs2ro')
    .getSheetByName("TIETKHUANDUNGCU");

  const data = sheet.getDataRange().getValues();

  for (let i = 1; i < data.length; i++) {
    if (data[i][0] == id) { // ✅ dùng ID
      sheet.getRange(i + 1, 12).setValue(trangthai);
      break;
    }
  }
}

function onChange() {
  const sheet = SpreadsheetApp.openById('19vz99n7clMN3ey4k_SSD8iXYIhZe0IR0oh5oaZZs2ro')
    .getSheetByName('TIETKHUANDUNGCU');

  sheet.getRange("M2").setValue(new Date());
}